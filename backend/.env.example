# ============================================================
# Material Solutions — Backend Environment Variables
# ============================================================
# Copy this file to .env for local development.
# For Railway deployment, set these in the Railway dashboard.

# ─── Database ────────────────────────────────────────────────
# Railway auto-sets DATABASE_URL when you add the PostgreSQL addon.
# Override only if connecting to an external database.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example: https://material-solutions.vercel.app,https://app.materialsolutionsnj.com
ALLOWED_ORIGINS=https://material-solutions.vercel.app

# ─── Authentication ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<YOUR_64_CHAR_HEX_SECRET>
JWT_REFRESH_SECRET=<YOUR_64_CHAR_HEX_SECRET>

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Gemini ─────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Email (SMTP) ───────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<your-email@gmail.com>
EMAIL_PASS=<your-app-password>
COMPANY_EMAIL=notifications@materialsolutions.com

# ─── Twilio (SMS) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Hunter.io (Email Discovery) ────────────────────────────
HUNTER_API_KEY=

# ─── CRM Integrations ───────────────────────────────────────
GOHIGHLEVEL_API_KEY=
GOHIGHLEVEL_LOCATION_ID=
HUBSPOT_API_KEY=
HUBSPOT_WEBHOOK_SECRET=

# ─── Google ─────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=

# ─── Trigify / Apollo Signals ────────────────────────────────
TRIGIFY_WEBHOOK_SECRET=
APOLLO_WEBHOOK_SECRET=
