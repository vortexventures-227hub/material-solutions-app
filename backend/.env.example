# Database
DATABASE_URL=postgresql://localhost:5432/material_solutions
DATABASE_SSL=false  # Set to 'false' for local dev; omit or set 'true' for production

# Server
PORT=3001
NODE_ENV=development

# CORS - Comma-separated list of allowed origins (required for production)
# Example: ALLOWED_ORIGINS=https://materialsolutions.com,https://admin.materialsolutions.com
ALLOWED_ORIGINS=http://localhost:3000

# OpenAI (for future Vision AI integration)
OPENAI_API_KEY=your_key_here

# Gemini (alternative Vision AI)
GEMINI_API_KEY=your_key_here

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
COMPANY_EMAIL=notifications@materialsolutions.com

# Authentication (REQUIRED)
# Generate strong random secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-char-random-string-here
JWT_REFRESH_SECRET=your-64-char-random-string-here
