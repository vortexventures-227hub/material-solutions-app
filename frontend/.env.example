# Material Solutions - Environment Variables
# Copy this file to .env and fill in the values

# ==========================================
# REQUIRED - Backend API URL
# ==========================================
# The Railway backend URL (no trailing slash)
REACT_APP_API_URL=https://your-backend-url.up.railway.app

# ==========================================
# OPTIONAL - Analytics
# ==========================================
# REACT_APP_GA_TRACKING_ID=G-XXXXXXXXXX

# ==========================================
# DEVELOPMENT ONLY
# ==========================================
# These are only used in development (npm start)
# DO NOT use these in production - backend uses Railway env vars
# PORT=3000
